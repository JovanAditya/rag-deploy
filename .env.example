# ==============================================
# RAG DEPLOY - ENVIRONMENT CONFIGURATION
# ==============================================
# Copy this file to .env and adjust the values
# These variables will be passed to containers via docker compose

# ==============================================
# LLM CONFIGURATION
# ==============================================
# Options: gemini (cloud) or ollama (local)
LLM_PROVIDER=gemini
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4000

# --- Google Gemini (Default, Recommended) ---
# Create a key at https://aistudio.google.com/
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# --- Ollama / Local LLM (Alternative, no API key) ---
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:latest

# ==============================================
# RAG PARAMETERS
# ==============================================
PIPELINE_TYPE=advanced
MAX_RESULTS=5
USE_RERANKING=true
EMBEDDING_MODEL=indobenchmark/indobert-base-p2
# Embedding device: cpu (default) or cuda (if NVIDIA GPU is available)
EMBEDDING_DEVICE=cpu

# ==============================================
# DATABASE CONFIGURATION
# ==============================================
DB_USERNAME=raguser
DB_PASSWORD=your-secure-password-here
DB_DATABASE=academic_rag

# ==============================================
# LARAVEL APP CONFIGURATION
# ==============================================
# Generate with: docker compose run --rm rag-web php artisan key:generate --show
APP_KEY=base64:your-app-key-here
APP_URL=http://localhost:8000
DEBUG=false

# ==============================================
# API SECURITY
# ==============================================
API_SECRET_KEY=your-secret-key-here

# ==============================================
# PORTS (Optional - Defaults shown)
# ==============================================
# API_PORT=5001
# WEB_PORT=8000
# MYSQL_PORT=3306
