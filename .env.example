# ==============================================
# RAG DEPLOY - ENVIRONMENT CONFIGURATION
# ==============================================
# Salin file ini ke .env dan sesuaikan nilainya
# Environment variables ini akan diteruskan ke container via docker compose

# ==============================================
# LLM CONFIGURATION
# ==============================================
# Provider Options: gemini, openai, anthropic, ollama, qwen, llama

# 1. Google Gemini (Default)
LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# 2. OpenAI
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_MODEL=gpt-3.5-turbo

# 3. Anthropic
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
# ANTHROPIC_MODEL=claude-3-haiku-20240307

# 4. Ollama / Local LLM
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_MODEL=llama3.2:latest

# 5. Qwen (via Ollama)
# LLM_PROVIDER=qwen
# QWEN_MODEL=qwen3:8b

# 6. Llama (via Ollama)
# LLM_PROVIDER=llama
# LLAMA_MODEL=llama3.2:latest

# LLM Parameters
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4000

# ==============================================
# RAG PARAMETERS
# ==============================================
PIPELINE_TYPE=advanced
MAX_RESULTS=5
USE_RERANKING=true
EMBEDDING_MODEL=indobenchmark/indobert-base-p2

# ==============================================
# DATABASE CONFIGURATION
# ==============================================
DB_USERNAME=raguser
DB_PASSWORD=your-secure-password-here
DB_DATABASE=academic_rag

# ==============================================
# LARAVEL APP CONFIGURATION
# ==============================================
# Generate dengan: docker compose run --rm rag-web php artisan key:generate --show
APP_KEY=base64:your-app-key-here
APP_URL=http://localhost:8000
DEBUG=false

# ==============================================
# API SECURITY
# ==============================================
API_SECRET_KEY=your-secret-key-here

# ==============================================
# PORTS (Optional - Defaults shown)
# ==============================================
# API_PORT=5001
# WEB_PORT=8000
# MYSQL_PORT=3306
